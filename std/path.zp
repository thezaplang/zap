import "std/string";

pub ext fun parent(path: String) String;
pub ext fun basename(path: String) String;

pub fun join(a: String, b: String) String {
  if string.len(a) == 0 {
    return b;
  }

  if string.len(b) == 0 {
    return a;
  }

  if string.at(b, 0) == '/' {
    return b;
  }

  if string.at(a, string.len(a) - 1) == '/' {
    return a ~ b;
  }

  return a ~ '/' ~ b;
}
