{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Zap",
	"patterns": [
		{
			"include": "#comments"
		},
		{
			"include": "#keywords"
		},
		{
			"include": "#declarations"
		},
		{
			"include": "#types"
		},
		{
			"include": "#namespaces"
		},
		{
			"include": "#members"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#numbers"
		},
		{
			"include": "#constants"
		}
	],
	"repository": {
		"constants": {
			"patterns": [{
				"name": "constant.language.zap",
				"match": "\\b(true|false)\\b"
			}]
		},
		"comments": {
			"patterns": [{
				"name": "comment.line.double-slash.zap",
				"match": "//.*$"
			}]
		},
		"numbers": {
    	"patterns": [{
        "name": "constant.numeric.zap",
        "match": "\\b\\d+(\\.\\d+)?\\b"
			}]
		},
		"keywords": {
			"patterns": [{
				"name": "keyword.control.zap",
				"match": "\\b(if|else|while|for|return|fun|import|var|ext|pub|priv|record|enum|struct|break|continue|global|const|alias|ref|as|match|module|impl|static)\\b"
			}]
		},
		"declarations": {
			"patterns": [
				{
					"name": "entity.name.function.zap",
					"match": "\\b(?:fun|ext\\s+fun)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
					"captures": {
						"1": {
							"name": "entity.name.function.zap"
						}
					}
				},
				{
					"name": "entity.name.type.zap",
					"match": "\\b(?:record|struct|enum|alias)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
					"captures": {
						"1": {
							"name": "entity.name.type.zap"
						}
					}
				},
				{
					"name": "variable.other.definition.zap",
					"match": "\\b(?:var|const)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
					"captures": {
						"1": {
							"name": "variable.other.definition.zap"
						}
					}
				},
				{
					"name": "variable.parameter.zap",
					"match": "\\b(?:ref\\s+)?([A-Za-z_][A-Za-z0-9_]*)\\s*:",
					"captures": {
						"1": {
							"name": "variable.parameter.zap"
						}
					}
				},
				{
					"name": "entity.name.namespace.zap",
					"match": "\\bimport\\s+\"[^\"]+\"\\s+as\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
					"captures": {
						"1": {
							"name": "entity.name.namespace.zap"
						}
					}
				},
				{
					"name": "variable.other.alias.zap",
					"match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s+as\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
					"captures": {
						"1": {
							"name": "variable.other.readwrite.zap"
						},
						"2": {
							"name": "variable.other.alias.zap"
						}
					}
				}
			]
		},
		"types": {
			"patterns": [
				{
					"name": "support.type.builtin.zap",
					"match": "\\b(?:Int|Int8|Int16|Int32|Int64|UInt|UInt8|UInt16|UInt32|UInt64|Float|Float32|Float64|Bool|Void|Char|String)\\b"
				},
				{
					"name": "support.type.zap",
					"match": ":\\s*([A-Za-z_][A-Za-z0-9_]*(?:\\s*\\.\\s*[A-Za-z_][A-Za-z0-9_]*)*)\\b",
					"captures": {
						"1": {
							"name": "support.type.zap"
						}
					}
				},
				{
					"name": "support.type.zap",
					"match": "\\)\\s*([A-Za-z_][A-Za-z0-9_]*(?:\\s*\\.\\s*[A-Za-z_][A-Za-z0-9_]*)*)\\b",
					"captures": {
						"1": {
							"name": "support.type.zap"
						}
					}
				}
			]
		},
		"namespaces": {
			"patterns": [
				{
					"name": "entity.name.namespace.zap",
					"match": "\\bimport\\s+\"[^\"]+\"\\s+as\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
					"captures": {
						"1": {
							"name": "entity.name.namespace.zap"
						}
					}
				},
				{
					"name": "entity.name.namespace.zap",
					"match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\b(?=\\s*\\.)",
					"captures": {
						"1": {
							"name": "entity.name.namespace.zap"
						}
					}
				}
			]
		},
		"members": {
			"patterns": [
				{
					"name": "entity.name.function.zap",
					"match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
					"captures": {
						"1": {
							"name": "entity.name.function.zap"
						}
					}
				},
				{
					"name": "variable.other.property.zap",
					"match": "(?<=\\.)\\s*([A-Za-z_][A-Za-z0-9_]*)\\b",
					"captures": {
						"1": {
							"name": "variable.other.property.zap"
						}
					}
				}
			]
		},
		"strings": {
			"name": "string.quoted.double.zap",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape.zap",
					"match": "\\\\."
				}
			]
		}
	},
	"scopeName": "source.zap"
}
