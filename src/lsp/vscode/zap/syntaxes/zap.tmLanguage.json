{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Zap",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#declarations"
        },
        {
            "include": "#types"
        },
        {
            "include": "#namespaces"
        },
        {
            "include": "#members"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#constants"
        }
    ],
    "repository": {
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.zap",
                    "match": "\\b(true|false|null)\\b"
                }
            ]
        },
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.zap",
                    "match": "//.*$"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.zap",
                    "match": "\\b\\d+(\\.\\d+)?\\b"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.zap",
                    "match": "\\b(if|else|iftype|while|for|return|fun|import|var|ext|pub|priv|prot|record|enum|struct|class|break|continue|global|const|alias|ref|as|match|module|impl|static|unsafe|new|self|where|weak)\\b"
                }
            ]
        },
        "declarations": {
            "patterns": [
                {
                    "name": "entity.name.function.zap",
                    "match": "\\b(?:unsafe\\s+fun|fun|ext\\s+fun)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
                    "captures": {
                        "1": {
                            "name": "entity.name.function.zap"
                        }
                    }
                },
                {
                    "name": "entity.name.type.zap",
                    "match": "\\b(?:record|struct|unsafe\\s+struct|class|enum|alias)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
                    "captures": {
                        "1": {
                            "name": "entity.name.type.zap"
                        }
                    }
                },
                {
                    "name": "variable.other.definition.zap",
                    "match": "\\b(?:var|const)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
                    "captures": {
                        "1": {
                            "name": "variable.other.definition.zap"
                        }
                    }
                },
                {
                    "name": "variable.parameter.zap",
                    "match": "\\b(?:ref\\s+)?([A-Za-z_][A-Za-z0-9_]*)\\s*:",
                    "captures": {
                        "1": {
                            "name": "variable.parameter.zap"
                        }
                    }
                },
                {
                    "name": "entity.name.namespace.zap",
                    "match": "\\bimport\\s+\"[^\"]+\"\\s+as\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
                    "captures": {
                        "1": {
                            "name": "entity.name.namespace.zap"
                        }
                    }
                },
                {
                    "name": "variable.other.alias.zap",
                    "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s+as\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
                    "captures": {
                        "1": {
                            "name": "variable.other.readwrite.zap"
                        },
                        "2": {
                            "name": "variable.other.alias.zap"
                        }
                    }
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "support.type.builtin.zap",
                    "match": "\\b(?:Int|Int8|Int16|Int32|Int64|UInt|UInt8|UInt16|UInt32|UInt64|Float|Float32|Float64|Bool|Void|Char|String)\\b"
                },
                {
                    "name": "support.type.zap",
                    "match": ":\\s*((?:\\.\\.\\.\\s*)?(?:\\*\\s*)*[A-Za-z_][A-Za-z0-9_]*(?:\\s*\\.\\s*[A-Za-z_][A-Za-z0-9_]*)*(?:\\s*<\\s*(?:[A-Za-z_][A-Za-z0-9_]*(?:\\s*\\.\\s*[A-Za-z_][A-Za-z0-9_]*)*)(?:\\s*,\\s*(?:[A-Za-z_][A-Za-z0-9_]*(?:\\s*\\.\\s*[A-Za-z_][A-Za-z0-9_]*)*))*\\s*>)?)\\b",
                    "captures": {
                        "1": {
                            "name": "support.type.zap"
                        }
                    }
                },
                {
                    "name": "support.type.zap",
                    "match": "\\)\\s*((?:\\.\\.\\.\\s*)?(?:\\*\\s*)*[A-Za-z_][A-Za-z0-9_]*(?:\\s*\\.\\s*[A-Za-z_][A-Za-z0-9_]*)*(?:\\s*<\\s*(?:[A-Za-z_][A-Za-z0-9_]*(?:\\s*\\.\\s*[A-Za-z_][A-Za-z0-9_]*)*)(?:\\s*,\\s*(?:[A-Za-z_][A-Za-z0-9_]*(?:\\s*\\.\\s*[A-Za-z_][A-Za-z0-9_]*)*))*\\s*>)?)\\b",
                    "captures": {
                        "1": {
                            "name": "support.type.zap"
                        }
                    }
                },
                {
                    "name": "entity.name.function.zap",
                    "match": "\\b(?:unsafe\\s+fun|fun|ext\\s+fun)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(?=<\\s*[A-Za-z_][A-Za-z0-9_]*(?:\\s*,\\s*[A-Za-z_][A-Za-z0-9_]*)*\\s*>)",
                    "captures": {
                        "1": {
                            "name": "entity.name.function.zap"
                        }
                    }
                },
                {
                    "name": "meta.generic.declaration.zap",
                    "match": "(?<=\\b(?:unsafe\\s+fun|fun|ext\\s+fun)\\s+[A-Za-z_][A-Za-z0-9_]*\\s*)(<)\\s*([A-Za-z_][A-Za-z0-9_]*(?:\\s*,\\s*[A-Za-z_][A-Za-z0-9_]*)*)\\s*(>)",
                    "captures": {
                        "1": {
                            "name": "punctuation.definition.generic.begin.zap"
                        },
                        "2": {
                            "patterns": [
                                {
                                    "name": "entity.name.type.parameter.zap",
                                    "match": "[A-Za-z_][A-Za-z0-9_]*"
                                },
                                {
                                    "name": "punctuation.separator.generic.zap",
                                    "match": ","
                                }
                            ]
                        },
                        "3": {
                            "name": "punctuation.definition.generic.end.zap"
                        }
                    }
                },
                {
                    "name": "support.type.zap",
                    "match": "\\b([A-Za-z_][A-Za-z0-9_]*(?:\\s*\\.\\s*[A-Za-z_][A-Za-z0-9_]*)*)\\s*(<\\s*(?:[A-Za-z_][A-Za-z0-9_]*(?:\\s*\\.\\s*[A-Za-z_][A-Za-z0-9_]*)*)(?:\\s*,\\s*(?:[A-Za-z_][A-Za-z0-9_]*(?:\\s*\\.\\s*[A-Za-z_][A-Za-z0-9_]*)*))*\\s*>)",
                    "captures": {
                        "1": {
                            "name": "support.type.zap"
                        },
                        "2": {
                            "patterns": [
                                {
                                    "name": "punctuation.definition.generic.begin.zap",
                                    "match": "<"
                                },
                                {
                                    "name": "entity.name.type.parameter.zap",
                                    "match": "[A-Za-z_][A-Za-z0-9_]*"
                                },
                                {
                                    "name": "punctuation.separator.generic.zap",
                                    "match": ","
                                },
                                {
                                    "name": "punctuation.definition.generic.end.zap",
                                    "match": ">"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "entity.name.type.parameter.zap",
                    "match": "\\biftype\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*==",
                    "captures": {
                        "1": {
                            "name": "entity.name.type.parameter.zap"
                        }
                    }
                },
                {
                    "name": "support.type.zap",
                    "match": "\\biftype\\s+[A-Za-z_][A-Za-z0-9_]*\\s*==\\s*([A-Za-z_][A-Za-z0-9_]*(?:\\s*\\.\\s*[A-Za-z_][A-Za-z0-9_]*)*(?:\\s*<\\s*(?:[A-Za-z_][A-Za-z0-9_]*(?:\\s*\\.\\s*[A-Za-z_][A-Za-z0-9_]*)*)(?:\\s*,\\s*(?:[A-Za-z_][A-Za-z0-9_]*(?:\\s*\\.\\s*[A-Za-z_][A-Za-z0-9_]*)*))*\\s*>)?)",
                    "captures": {
                        "1": {
                            "name": "support.type.zap"
                        }
                    }
                },
                {
                    "name": "entity.name.type.parameter.zap",
                    "match": "\\bwhere\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*:",
                    "captures": {
                        "1": {
                            "name": "entity.name.type.parameter.zap"
                        }
                    }
                },
                {
                    "name": "support.type.zap",
                    "match": "\\bwhere\\s+[A-Za-z_][A-Za-z0-9_]*\\s*:\\s*([A-Za-z_][A-Za-z0-9_]*(?:\\s*\\.\\s*[A-Za-z_][A-Za-z0-9_]*)*(?:\\s*<\\s*(?:[A-Za-z_][A-Za-z0-9_]*(?:\\s*\\.\\s*[A-Za-z_][A-Za-z0-9_]*)*)(?:\\s*,\\s*(?:[A-Za-z_][A-Za-z0-9_]*(?:\\s*\\.\\s*[A-Za-z_][A-Za-z0-9_]*)*))*\\s*>)?)",
                    "captures": {
                        "1": {
                            "name": "support.type.zap"
                        }
                    }
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.logical.zap",
                    "match": "&&|\\|\\|"
                },
                {
                    "name": "keyword.operator.comparison.zap",
                    "match": "==|!=|>=|<=|>|<"
                },
                {
                    "name": "keyword.operator.assignment.zap",
                    "match": "="
                },
                {
                    "name": "keyword.operator.arithmetic.zap",
                    "match": "\\+|-|/|%|\\^|~"
                },
                {
                    "name": "keyword.operator.unary.zap",
                    "match": "!"
                },
                {
                    "name": "keyword.operator.pointer.zap",
                    "match": "(?<![A-Za-z0-9_])(?:&|\\*)(?![=])"
                }
            ]
        },
        "namespaces": {
            "patterns": [
                {
                    "name": "entity.name.namespace.zap",
                    "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\b(?=\\s*\\.)",
                    "captures": {
                        "1": {
                            "name": "entity.name.namespace.zap"
                        }
                    }
                }
            ]
        },
        "members": {
            "patterns": [
                {
                    "name": "entity.name.function.zap",
                    "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
                    "captures": {
                        "1": {
                            "name": "entity.name.function.zap"
                        }
                    }
                },
                {
                    "name": "variable.other.property.zap",
                    "match": "(?<=\\.)\\s*([A-Za-z_][A-Za-z0-9_]*)\\b",
                    "captures": {
                        "1": {
                            "name": "variable.other.property.zap"
                        }
                    }
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.zap",
                    "match": "\"(?:[^\"\\\\]|\\\\.)*\""
                }
            ]
        }
    },
    "scopeName": "source.zap"
}
