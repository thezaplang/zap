import "std/convert" { toString, toInt, toFloat, toFloat64, toBool, toChar, parseInt, parseIntOr, ParseIntError };
import "std/string" { eq };

fun main() Int {
    if !eq(toString(42), "42") {
        return 1;
    }
    if !eq(toString(2.5), "2.5") {
        return 2;
    }
    if !eq(toString(true), "true") {
        return 3;
    }
    if !eq(toString('Z'), "Z") {
        return 4;
    }

    if toInt(true) != 1 {
        return 5;
    }
    if toInt('A') != 65 {
        return 6;
    }
    if toInt(8.9) != 8 {
        return 7;
    }

    if toFloat(7) != 7.0 {
        return 8;
    }
    if toFloat64(false) != toFloat64(0.0) {
        return 9;
    }

    if !toBool("true") {
        return 10;
    }
    if toBool(0) {
        return 11;
    }

    if toChar(66) != 'B' {
        return 12;
    }

    var parsed1: Int = parseInt("42") or 0;
    if parsed1 != 42 {
        return 13;
    }
    var parsed2: Int = parseInt("   -19  ") or 0;
    if parsed2 != -19 {
        return 14;
    }
    if parseIntOr("abc", 77) != 77 {
        return 15;
    }

    var bad: Int = parseInt("12x") or -1;
    if bad != -1 {
        return 16;
    }

    var emptyErr: Int = parseInt("   ") or err {
        if err == ParseIntError.Empty {
            1
        } else {
            0
        }
    };
    if emptyErr != 1 {
        return 17;
    }

    return 0;
}
