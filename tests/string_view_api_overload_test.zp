import "std/string";
import "std/fs";
import "std/process";
import "std/io";
import "std/path";

fun main() Int {
  var base: string.StringView = string.view("/tmp");
  var name: string.StringView = string.view("zap_overload_test_file.txt");
  var p: String = path.join(base, name);

  if fs.writeFile(p, string.view("abc")) != 0 {
    return 1;
  }
  if !fs.exists(string.view(p)) {
    return 2;
  }

  var content: String = fs.readFile(string.view(p));
  if !string.eq(content, "abc") {
    return 3;
  }

  if fs.remove(string.view(p)) != 0 {
    return 4;
  }

  if process.exec(string.view("true")) != 0 {
    return 5;
  }

  io.println(string.view("ok"));
  return 0;
}
