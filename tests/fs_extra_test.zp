import "std/fs";
import "std/path";
import "std/process";
import "std/string";
import "std/collection";

fun main() Int {
    var root: String = path.join("/tmp", "zap_fs_extra");
    var nestedDir: String = path.join(root, "a/b/c");
    var srcFile: String = path.join(root, "source.txt");
    var copiedFile: String = path.join(root, "copies/copied.txt");
    var movedFile: String = path.join(root, "moved/moved.txt");
    var touchFile: String = path.join(root, "touched/empty.txt");
    var missingFile: String = path.join(root, "missing.txt");
    var linesFile: String = path.join(root, "lines/data.txt");

    process.exec("rm -rf \"" + root + "\"");

    if fs.exists(root) {
        return 1;
    }

    fs.ensureDir(nestedDir) or err {
        return 2;
    };

    if !fs.isDir(nestedDir) {
        return 3;
    }

    fs.ensureDir(nestedDir) or err {
        return 4;
    };

    fs.writeFileSafe(srcFile, "alpha") or err {
        return 5;
    };

    if !fs.isFile(srcFile) {
        return 6;
    }

    var srcContent: String = fs.readFile(srcFile) or err { return 7; };
    if !string.eq(srcContent, "alpha") {
        return 7;
    }

    fs.copyFile(srcFile, copiedFile) or err {
        return 8;
    };

    if !fs.isFile(copiedFile) {
        return 9;
    }

    var copiedContent: String = fs.readFile(copiedFile) or err { return 10; };
    if !string.eq(copiedContent, "alpha") {
        return 10;
    }

    fs.move(copiedFile, movedFile) or err {
        return 11;
    };

    if fs.exists(copiedFile) {
        return 12;
    }

    if !fs.isFile(movedFile) {
        return 13;
    }

    fs.writeFileSafe(movedFile, "beta") or err {
        return 14;
    };

    var movedContent: String = fs.readFile(movedFile) or err { return 15; };
    if !string.eq(movedContent, "beta") {
        return 15;
    }

    fs.touch(touchFile) or err {
        return 16;
    };

    if !fs.isFile(touchFile) {
        return 17;
    }

    var touchContent: String = fs.readFile(touchFile) or err { return 18; };
    if !string.eq(touchContent, "") {
        return 18;
    }

    fs.touch(touchFile) or err {
        return 19;
    };

    if fs.exists(missingFile) {
        return 20;
    }

    fs.remove(movedFile) or err {
        return 21;
    };

    if fs.exists(movedFile) {
        return 22;
    }

    fs.remove(touchFile) or err {
        return 23;
    };

    if fs.exists(touchFile) {
        return 24;
    }

    var lines: collection.List<String> = new collection.List<String>();
    lines.push("first");
    lines.push("second");
    lines.push("third");

    fs.writeLines(linesFile, lines) or err {
        return 25;
    };

    if !fs.isFile(linesFile) {
        return 26;
    }

    var readBack: collection.List<String> = fs.readLines(linesFile) or err { return 27; };
    if readBack.len() != 3 {
        return 27;
    }

    if !string.eq(readBack.at(0), "first") {
        return 28;
    }

    if !string.eq(readBack.at(1), "second") {
        return 29;
    }

    if !string.eq(readBack.at(2), "third") {
        return 30;
    }

    process.exec("rm -rf \"" + root + "\"");
    return 0;
}
