struct Node {
  value: Int,
  next: *Node
}

unsafe fun sum_list(head: *Node) Int {
  var total: Int = 0;
  var current: *Node = head;
  
  while current != null {
    total = total + (*current).value;
    current = (*current).next;
  }
  
  return total;
}

fun main() Int {
  unsafe {
    var n2: Node = Node { value: 30, next: null };
    var n1: Node = Node { value: 20, next: &n2 };
    
    var result: Int = sum_list(&n1);
    
    if result != 50 {
      return 1;
    }
    
    return 0;
  }
}
