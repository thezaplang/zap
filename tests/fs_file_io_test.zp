import "std/fs";
import "std/process";
import "std/string";
import "std/path";

fun main() Int {
    var filePath: String = path.join("/tmp", "zap_fs_file_io.txt");
    var content: String = "hello\nzap";

    process.exec("rm -f \"" + filePath + "\"");

    fs.writeFile(filePath, content) or err {
        return 1;
    };

    if !fs.exists(filePath) {
        return 2;
    }

    if !fs.isFile(filePath) {
        return 3;
    }

    var firstRead: String = fs.readFile(filePath) or err { return 4; };
    if !string.eq(firstRead, content) {
        return 4;
    }

    fs.writeFile(filePath, "rewritten") or err {
        return 5;
    };

    var secondRead: String = fs.readFile(filePath) or err { return 6; };
    if !string.eq(secondRead, "rewritten") {
        return 6;
    }

    process.exec("rm -f \"" + filePath + "\"");

    var missingFailed: Bool = false;
    fs.readFile(filePath) or err {
        missingFailed = err == fs.FsError.NotFound;
        ""
    };
    if !missingFailed {
        return 7;
    }

    return 0;
}
