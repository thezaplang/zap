// Regression: global var initialized with literal '+' concatenation is folded.

global var GREETING: String = "hello, " + "world";
global var SUM: Int = 1 + 2 * 3;

fun main() Int {
    var len: Int = 0;
    var i: Int = 0;
    // "hello, world" has 12 characters.
    while i < 12 {
        len = len + 1;
        i = i + 1;
    }
    if len != 12 {
        return 1;
    }
    // SUM should fold to 7.
    return SUM + 35; // 42
}
