fun main() Int {
    var x: Int = 10;
    x += 5;  // 15
    x -= 3;  // 12
    x *= 2;  // 24
    x /= 4;  // 6
    x %= 4;  // 2
    x <<= 3; // 16
    x >>= 1; // 8
    x |= 1;  // 9
    x &= 6;  // 0
    x ^= 2;  // 2
    x++;     // 3
    x--;     // 2

    var sum: Int = 0;
    for (var i: Int = 0; i < 5; i++) {
        sum += i; // 0+1+2+3+4 = 10
    }

    var arr: [3]Int = {1, 2, 3};
    arr[2] *= 10; // 30

    return x + sum + arr[2]; // 2 + 10 + 30 = 42
}
