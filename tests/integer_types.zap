import "std/prelude" { printInt };

fun main() {
    var a: Int8 = 1;
    var b: Int16 = 2;
    var c: Int32 = 3;
    var d: Int64 = 4;
    var e: UInt8 = 5;
    var f: UInt16 = 6;
    var g: UInt32 = 7;
    var h: UInt64 = 8;
    var i: Int = 9;
    var j: UInt = 10;

    printInt(a);
    printInt(b);
    printInt(c);
    printInt(d);
    printInt(e);
    printInt(f);
    printInt(g);
    printInt(h);
    printInt(i);
    printInt(j);
}
