import "std/fs";
import "std/process";

fun main() Int {
    var root: String = "/tmp/zap_fs_mkdir";
    var nested: String = root + "/a/b/c";
    var filePath: String = root + "/marker.txt";

    process.exec("rm -rf \"" + root + "\"");

    if fs.exists(root) {
        return 1;
    }

    fs.mkdir(root) or err {
        return 2;
    };

    if !fs.isDir(root) {
        return 3;
    }

    fs.mkdirAll(nested) or err {
        return 4;
    };

    if !fs.isDir(nested) {
        return 5;
    }

    fs.mkdirAll(nested) or err {
        return 6;
    };

    if process.exec("sh -c 'printf x > \"" + filePath + "\"'") != 0 {
        return 7;
    }

    var rejectedFilePath: Bool = false;
    fs.mkdir(filePath) or err {
        rejectedFilePath = true;
    };
    if !rejectedFilePath {
        return 8;
    }

    process.exec("rm -rf \"" + root + "\"");

    if fs.exists(root) {
        return 9;
    }

    return 0;
}
