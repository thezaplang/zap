import "std/string";

fun main() Int {
    if string.len("abc") != 3 {
        return 1;
    }

    if string.at("zap", 1) != 'a' {
        return 2;
    }

    var one: String = string.fromChar('x');
    if string.len(one) != 1 {
        return 3;
    }
    if string.at(one, 0) != 'x' {
        return 4;
    }

    var pushed: String = string.pushChar("za", 'p');
    if string.len(pushed) != 3 {
        return 5;
    }
    if string.at(pushed, 2) != 'p' {
        return 6;
    }

    var sub: String = string.slice("hello", 1, 3);
    if string.len(sub) != 3 {
        return 7;
    }
    if string.at(sub, 0) != 'e' {
        return 8;
    }
    if string.at(sub, 2) != 'l' {
        return 9;
    }

    if !string.eq("zap", "zap") {
        return 10;
    }
    if string.eq("zap", "zip") {
        return 11;
    }

    if string.indexOf("hello world", "world") != 6 {
        return 12;
    }
    if string.indexOf("hello", "x") != -1 {
        return 13;
    }

    if !string.startsWith("zaplang", "zap") {
        return 14;
    }
    if string.startsWith("zaplang", "lang") {
        return 15;
    }

    var trimmed: String = string.trim(" \t\nzap  \r");
    if !string.eq(trimmed, "zap") {
        return 16;
    }

    var p1: string.SplitPair = string.splitOnce("a,b,,c", ',');
    if !p1.found {
        return 17;
    }
    if !string.eq(p1.left, "a") {
        return 18;
    }
    if !string.eq(p1.right, "b,,c") {
        return 19;
    }

    var p2: string.SplitPair = string.splitOnce(p1.right, ',');
    if !p2.found {
        return 20;
    }
    if !string.eq(p2.left, "b") {
        return 21;
    }

    return 0;
}
