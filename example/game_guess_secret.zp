import "std/io" { println };
import "std/process";
import "std/string";

fun main() Int {
    var secret: String = "zap";

    if process.argc() < 2 {
        println("usage: game_guess_secret <word>");
        return 1;
    }

    if string.eq(process.argv(1), secret) {
        println("you found the secret");
        return 0;
    }

    println("wrong guess");
    return 2;
}
