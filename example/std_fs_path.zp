import "std/io" { println };
import "std/fs";
import "std/path";

fun main() Int {
    var dir: String = path.join("/tmp", "zap_example");
    var file: String = path.join(dir, "note.txt");

    fs.mkdirAll(dir) or err {
        return 1;
    };

    fs.writeFile(file, "hello from zap") or err {
        return 2;
    };

    println(path.basename(file));
    println(fs.readFile(file) or "");
    println(path.parent(file));
    return 0;
}
