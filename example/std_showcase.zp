import "std/io" { println };
import "std/fs";
import "std/path";
import "std/process";

fun main() Int {
  var root: String = path.join("/tmp", "zap_showcase");
  var note: String = path.join(root, "note.txt");

  fs.mkdirAll(root) or err { return 1; };
  fs.writeFile(note, "cwd: " + process.cwd()) or err { return 1; };

  println(path.basename(note));
  println(path.parent(note));
  println(fs.readFile(note) or "");
  return 0;
}
